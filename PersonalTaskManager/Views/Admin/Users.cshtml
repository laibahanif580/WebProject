@using Microsoft.AspNetCore.Identity
@model List<IdentityUser>

@{
    ViewData["Title"] = "All Users";

    // Get the user claims dictionary safely
    var userClaims = ViewBag.UserClaims as Dictionary<string, bool> ?? new Dictionary<string, bool>();
}

<h2 class="mb-4">Registered Users</h2>

<table class="table table-striped table-bordered">
    <thead class="table-dark">
        <tr>
            <th>#</th>
            <th>Username</th>
            <th>Email</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @for (int i = 0; i < Model.Count; i++)
        {
            var user = Model[i];
            <tr>
                <td>@(i + 1)</td>
                <td>@user.UserName</td>
                <td>@user.Email</td>
                <td>
                    @if (!userClaims.ContainsKey(user.Id) || !userClaims[user.Id]) 
                    @* if user is not an editor *@
                    {
                        <!-- Form for AJAX call -->
                        <form class="make-editor-form" data-user-id="@user.Id" method="post" style="display:inline;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@user.Id" />
                            <button type="submit" class="btn btn-sm btn-primary">Make Editor</button>
                        </form>
                    }
                    else
                    {
                        <span class="badge bg-success editor-badge" data-user-id="@user.Id">Editor</span>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

<a class="btn btn-secondary mb-3" asp-controller="Admin" asp-action="Dashboard">← Back to Dashboard</a>
