@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

<style>
    .nav-link:hover,
    .nav-link:focus {
        text-decoration: underline !important;
    }
    
</style>

@if (SignInManager.IsSignedIn(User))
{
    var currentUser = await UserManager.GetUserAsync(User);
    var claims = await UserManager.GetClaimsAsync(currentUser!);

    // Check if user has Admin claim
    bool isAdmin = claims.Any(c => c.Type == "TaskPermission" && c.Value == "Admin");
    bool isEditor = claims.Any(c => c.Type == "TaskPermission" && c.Value == "Editor");
    bool isViewer = claims.Any(c => c.Type == "TaskPermission" && c.Value == "Viewer");

    if (isAdmin)
    {
        <li class="nav-item">
            <a class="nav-link text-white" asp-controller="Admin" asp-action="Dashboard">Admin Dashboard</a>
        </li>
        <li class="nav-item">
            <a class="nav-link text-white" asp-controller="Admin" asp-action="AllAnnouncements">Announcements</a>
        </li>
    }
    else
    {
        // Common links for Editor or Viewer
        <li class="nav-item">
            <a class="nav-link text-white" asp-controller="User" asp-action="Dashboard">Dashboard</a>
        </li>

        
            <li class="nav-item">
                <a class="nav-link text-white" asp-controller="Category" asp-action="Index">Categories</a>
            </li>


        <li class="nav-item">
            <a class="nav-link text-white" asp-controller="Task" asp-action="Index">All Tasks</a>
        </li>

        <li class="nav-item">
            <a class="nav-link text-white" asp-controller="User" asp-action="Announcements">Announcements</a>
        </li>
    }

    <li class="nav-item">
        <span class="nav-link text-white">Hello, @User.Identity.Name!</span>
    </li>
    <li class="nav-item">
        <form asp-area="Identity" asp-page="/Account/Logout" method="post" id="logoutForm" style="display:inline;">
            <button type="submit" class="btn btn-link nav-link text-white" style="padding:0;">Logout</button>
        </form>
    </li>
}
else
{
    <li class="nav-item">
        <a class="nav-link text-white" asp-controller="Home" asp-action="Index">Home</a>
    </li>
    <li class="nav-item">
        <a class="nav-link text-white" asp-area="Identity" asp-page="/Account/Login">Login</a>
    </li>
    <li class="nav-item">
        <a class="nav-link text-white" asp-area="Identity" asp-page="/Account/Register">Register</a>
    </li>
}
