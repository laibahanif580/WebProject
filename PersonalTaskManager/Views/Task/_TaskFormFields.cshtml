@model PersonalTaskManager.Models.UserTask

@Html.AntiForgeryToken()

<div class="mb-3">
    <label asp-for="Title" class="form-label fw-semibold"></label>
    <input asp-for="Title" class="form-control" placeholder="Enter task title"
           style="border-radius:25px; outline:none; border:1px solid rgba(0,0,0,0.1); 
                  background-color: rgba(255, 255, 255, 0.664);" required/>
    <span asp-validation-for="Title" class="text-danger"></span>
</div>

<div class="mb-3">
    <label asp-for="Description" class="form-label fw-semibold"></label>
    <textarea asp-for="Description" class="form-control" rows="3" placeholder="Enter task description"
              style="border-radius:25px; outline:none; border:1px solid rgba(0,0,0,0.1); 
                     background-color: rgba(255, 255, 255, 0.664);"></textarea>
    <span asp-validation-for="Description" class="text-danger"></span>
</div>

<div class="mb-3">
    <label asp-for="Category" class="form-label fw-semibold"></label>
    <select asp-for="Category" class="form-select" style="border-radius:25px;" required>
        <option value="">Select Category</option>
        <option>Work</option>
        <option>Personal</option>
    </select>
</div>

<div class="mb-3">
    <label asp-for="Status" class="form-label fw-semibold"></label>
    <select asp-for="Status" class="form-select" style="border-radius:25px;"required>
        <option>Pending</option>
        <option>In-Progress</option>
        <option>Completed</option>
    </select>
</div>

<div class="mb-3">
    <label asp-for="Priority" class="form-label fw-semibold"></label>
    <select asp-for="Priority" class="form-select" style="border-radius:25px;"required>
        <option>Low</option>
        <option>Medium</option>
        <option>High</option>
    </select>
</div>

<div class="mb-3">
    <label asp-for="DueDate" class="form-label fw-semibold"></label>
    <input asp-for="DueDate" type="date" class="form-control" 
           value="@DateTime.Now.ToString("yyyy-MM-dd")" 
           min="@DateTime.Now.ToString("yyyy-MM-dd")" 
           style="border-radius:25px;" required/>
</div>
