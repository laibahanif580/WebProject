@model PersonalTaskManager.Models.UserTask

@{
    ViewData["Title"] = "Delete Task";
}

<h2 class="text-center fw-bold mb-4" style="color:black;">Delete Task</h2>

<div class="my-3 p-4 " style="background-color:#f7f3f3; max-width:600px; border-radius:15px;">
    <h5>Are you sure you want to delete this task?</h5>
    <p><strong>Title:</strong> @Model.Title</p>
    <p><strong>Status:</strong> @Model.Status</p>
</div>

<form asp-action="delete" asp-route-id="@Model.TaskId" method="post">
    @Html.AntiForgeryToken()
    <button type="submit" class="btn btn-danger px-4 me-2">Yes, Delete</button>
    <a asp-action="Index" class="btn btn-secondary px-4">Cancel</a>
</form>
